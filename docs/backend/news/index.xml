<item>
  <title>Can quantum-mechanical description of physical reality be considered complete?</title>
  <dc:creator>Albert Einstein</dc:creator>
  <dc:creator>Boris Podolsky</dc:creator>
  <dc:creator>Nathan Rosen</dc:creator>
  <link>https://github.com/thalesmaoa/thalesmaoa.github.io/tree/main/docs/backend/news/paper-title/</link>
  <description><![CDATA[ 




